{
  "info": {
    "name": "Flight Route API",
    "description": "Postman collection covering every endpoint of the Flight Route API. Folders are organised module by module: Auth, Locations, Transportations, Routes.\n\n## Quick start\n1. Run **Auth → Login (Admin)** or **Login (Agency)** — the test script stores the JWT in the `accessToken` collection variable automatically.\n2. The other folders inherit Bearer authentication from the collection root, so every request is signed without further setup.\n3. Adjust `locationId`, `transportationId`, `originId`, `destinationId`, `searchDate` collection variables to match your seed data.\n\nDefault credentials seeded by Flyway migrations V5/V7:\n- Admin: `systemadmin` / `Anadolu1071*`\n- Agency: `systemagency` / `Anadolu1071*`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl",          "value": "http://localhost:8080", "type": "string" },
    { "key": "accessToken",      "value": "",                       "type": "string" },
    { "key": "adminUsername",    "value": "systemadmin",            "type": "string" },
    { "key": "adminPassword",    "value": "Anadolu1071*",           "type": "string" },
    { "key": "agencyUsername",   "value": "systemagency",           "type": "string" },
    { "key": "agencyPassword",   "value": "Anadolu1071*",           "type": "string" },
    { "key": "locationId",       "value": "1",                      "type": "string" },
    { "key": "transportationId", "value": "1",                      "type": "string" },
    { "key": "originId",         "value": "3",                      "type": "string" },
    { "key": "destinationId",    "value": "8",                      "type": "string" },
    { "key": "searchDate",       "value": "2026-05-04",             "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints. Login responses populate the `accessToken` collection variable used by all other folders.",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.expect(body.accessToken, 'accessToken').to.be.a('string').and.not.empty;",
                  "pm.collectionVariables.set('accessToken', body.accessToken);",
                  "console.log('accessToken stored (admin) — expires in', body.expiresIn, 's');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          }
        },
        {
          "name": "Login (Agency)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.expect(body.accessToken, 'accessToken').to.be.a('string').and.not.empty;",
                  "pm.collectionVariables.set('accessToken', body.accessToken);",
                  "console.log('accessToken stored (agency) — expires in', body.expiresIn, 's');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{agencyUsername}}\",\n  \"password\": \"{{agencyPassword}}\"\n}"
            }
          }
        },
        {
          "name": "Login — invalid credentials (expect 401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"systemadmin\",\n  \"password\": \"wrong-password\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Locations",
      "description": "CRUD for locations. Admin-only — Agency users will receive HTTP 403 here.",
      "item": [
        {
          "name": "List locations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/locations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "locations"]
            }
          }
        },
        {
          "name": "Get location by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/locations/{{locationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "locations", "{{locationId}}"]
            }
          }
        },
        {
          "name": "Create location",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body && body.id) {",
                  "    pm.collectionVariables.set('locationId', body.id);",
                  "    console.log('locationId stored:', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/locations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "locations"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Schiphol Airport\",\n  \"country\": \"Netherlands\",\n  \"city\": \"Amsterdam\",\n  \"code\": \"AMS\"\n}"
            }
          }
        },
        {
          "name": "Update location",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/locations/{{locationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "locations", "{{locationId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Amsterdam Schiphol Airport\",\n  \"country\": \"Netherlands\",\n  \"city\": \"Amsterdam\",\n  \"code\": \"AMS\"\n}"
            }
          }
        },
        {
          "name": "Delete location",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/locations/{{locationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "locations", "{{locationId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Transportations",
      "description": "CRUD for transportations. Admin-only — Agency users will receive HTTP 403 here.\n\n`type` must be one of: `FLIGHT`, `BUS`, `SUBWAY`, `UBER`.\n`operatingDays` is a set of ISO weekday numbers (1=Monday … 7=Sunday).",
      "item": [
        {
          "name": "List transportations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/transportations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transportations"]
            }
          }
        },
        {
          "name": "Get transportation by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/transportations/{{transportationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transportations", "{{transportationId}}"]
            }
          }
        },
        {
          "name": "Create transportation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body && body.id) {",
                  "    pm.collectionVariables.set('transportationId', body.id);",
                  "    console.log('transportationId stored:', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transportations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transportations"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originId\": {{originId}},\n  \"destinationId\": {{destinationId}},\n  \"type\": \"FLIGHT\",\n  \"operatingDays\": [1, 3, 5, 7]\n}"
            }
          }
        },
        {
          "name": "Update transportation",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transportations/{{transportationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transportations", "{{transportationId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originId\": {{originId}},\n  \"destinationId\": {{destinationId}},\n  \"type\": \"FLIGHT\",\n  \"operatingDays\": [1, 2, 3, 4, 5, 6, 7]\n}"
            }
          }
        },
        {
          "name": "Delete transportation",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/transportations/{{transportationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transportations", "{{transportationId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Routes",
      "description": "Route search. Available to both Admin and Agency users.\n\n`date` must be ISO-8601 (`YYYY-MM-DD`). The system computes the weekday and filters transportations whose `operatingDays` include it.",
      "item": [
        {
          "name": "Find routes (Taksim → Wembley)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/routes?originId={{originId}}&destinationId={{destinationId}}&date={{searchDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes"],
              "query": [
                { "key": "originId",      "value": "{{originId}}" },
                { "key": "destinationId", "value": "{{destinationId}}" },
                { "key": "date",          "value": "{{searchDate}}" }
              ]
            }
          }
        },
        {
          "name": "Find routes — missing parameters (expect 400)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/routes?originId={{originId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes"],
              "query": [
                { "key": "originId", "value": "{{originId}}" }
              ]
            }
          }
        },
        {
          "name": "Find routes — unknown location (expect 404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/routes?originId=999999&destinationId={{destinationId}}&date={{searchDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "routes"],
              "query": [
                { "key": "originId",      "value": "999999" },
                { "key": "destinationId", "value": "{{destinationId}}" },
                { "key": "date",          "value": "{{searchDate}}" }
              ]
            }
          }
        }
      ]
    }
  ]
}
